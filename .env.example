# PayPilot - environment template
# Copy to `.env` and fill in your key:  cp .env.example .env
# Note: tests mock the LLM and retriever, so no key/network is needed to run pytest.

# Your OpenAI API key (used by ChatOpenAI for diagnosis/draft and by OpenAIEmbeddings for RAG)
OPENAI_API_KEY=

# Chat model for the LangGraph nodes (overrides the gpt-4o-mini default in get_llm())
OPENAI_MODEL=gpt-4o-mini
